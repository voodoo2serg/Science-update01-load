POSTGRES_DB=science_concierge
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-db-password
BOT_TOKEN=replace-with-your-bot-token
SECRET_KEY=replace-with-a-very-long-random-secret-key-32-chars-min
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
APP_ENV=production
APP_NAME=Science Concierge
